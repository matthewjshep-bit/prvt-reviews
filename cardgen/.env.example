# cardgen — the render engine. Holds map + storage keys; the iframe never sees these.

PORT=3000

# --- Cloudflare R2 (rendered cards + provider caches) ---
# Without all of these, cardgen writes to local ./files and serves them at /files
# (dev only — production MUST use R2 so MMS/iMessage never hit Render).
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=cards
R2_PUBLIC_BASE=https://cards.knownintown.com

# This service's own public URL (only used by the local /files fallback).
CARDGEN_PUBLIC_URL=https://cards.prvtmkt.com

# --- Mapbox (optional — mapbox-pin / mapbox-parcel providers) ---
MAPBOX_TOKEN=pk.your-mapbox-token
# Override the King County parcel GIS layer if their service URL changes.
# MAPBOX_PARCEL_KINGCOUNTY_URL=https://.../MapServer/0

# --- Legacy /card SSRF allowlist (unchanged) ---
# ALLOWED_BG_HOSTS=api.prvtmkt.com

# --- Provider safety ---
# PROVIDER_RATE_PER_MIN=60
# BLOCKED_FETCH_HOSTS=extra.host.com
