# --- GoHighLevel ---
# Private Integration token from: sub-account → Settings → Private Integrations
# Scopes needed: locations/customValues.readonly, locations/customValues.write,
#                contacts.readonly, contacts.write,
#                conversations.write, conversations/message.write
GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The one sub-account this token belongs to (single-tenant guard).
GHL_LOCATION_ID=PvdeT4y6MyupP0pKMMjz

# --- Services ---
# Your deployed card image microservice (no trailing slash).
CARD_SERVICE_URL=https://cards.prvtmkt.com

# Public URL of THIS broker, used to build uploaded-logo URLs that GHL can fetch.
PUBLIC_BASE_URL=https://api.prvtmkt.com

# Only set if the Messaging page is served from a different origin than this API.
# APP_ORIGIN=https://app.prvtmkt.com

# Where uploaded logos are written (defaults to ./uploads).
# UPLOAD_DIR=/data/uploads

PORT=4000

# --- Card Studio: database (Render-managed Postgres) ---
# Without this, the broker falls back to a local JSON file (dev only).
# Apply schema once:  psql "$DATABASE_URL" -f schema.pg.sql
DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSL=require   # force relaxed SSL; auto-enabled for non-local hosts

# --- Card Studio: provider connection encryption (AES-256-GCM) ---
# Any long random string. Set BEFORE anyone creates a Connection.
CONNECTIONS_KEY=change-me-to-a-long-random-string

# --- Card Studio: Cloudflare R2 (broker uploads user image assets here) ---
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=cards
R2_PUBLIC_BASE=https://cards.knownintown.com

# Contact custom field the render webhook writes the image URL into.
# CARD_FIELD_KEY=card_image_url

# --- Supabase (server-side only — never expose the service-role key) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (Business Profile) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
