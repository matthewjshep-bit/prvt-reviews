# --- GoHighLevel ---
# Private Integration token from: sub-account → Settings → Private Integrations
# Scopes needed: locations/customValues.readonly, locations/customValues.write,
#                contacts.readonly, contacts.write,
#                conversations.write, conversations/message.write
GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The one sub-account this token belongs to (single-tenant guard).
GHL_LOCATION_ID=PvdeT4y6MyupP0pKMMjz

# --- Services ---
# Your deployed card image microservice (no trailing slash).
CARD_SERVICE_URL=https://cards.prvtmkt.com

# Public URL of THIS broker, used to build uploaded-logo URLs that GHL can fetch.
PUBLIC_BASE_URL=https://api.prvtmkt.com

# Only set if the Messaging page is served from a different origin than this API.
# APP_ORIGIN=https://app.prvtmkt.com

# Where uploaded logos are written (defaults to ./uploads).
# UPLOAD_DIR=/data/uploads

PORT=4000

# --- Supabase (server-side only — never expose the service-role key) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (Business Profile) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
